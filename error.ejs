<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error | Empiria</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    .glass { background: rgba(255,255,255,0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); }
    .gradient-text { background: linear-gradient(90deg, #7289DA, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  </style>
</head>
<body class="bg-[#0f172a] text-slate-200 font-sans min-h-screen flex flex-col items-center justify-center">
  <div class="glass p-10 rounded-3xl max-w-md w-full text-center shadow-2xl">
    <div class="w-16 h-16 bg-red-500/20 rounded-2xl flex items-center justify-center mx-auto mb-6">
      <i class="fas fa-exclamation-triangle text-red-400 text-3xl"></i>
    </div>
    <h1 class="text-3xl font-extrabold gradient-text mb-3">Oops!</h1>
    <p class="text-slate-400 mb-8"><%= message || "Something went wrong." %></p>
    <div class="flex gap-3 justify-center">
      <a href="/" class="bg-[#7289DA] hover:bg-[#5b6eae] px-5 py-2.5 rounded-xl font-medium transition-all text-white text-sm">
        <i class="fas fa-home mr-2"></i>Home
      </a>
      <a href="javascript:history.back()" class="glass hover:bg-white/10 px-5 py-2.5 rounded-xl font-medium transition-all text-sm">
        <i class="fas fa-arrow-left mr-2"></i>Go Back
      </a>
    </div>
  </div>
</body>
</html>
