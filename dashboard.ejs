<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Empiria</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .gradient-text { background: linear-gradient(90deg, #7289DA, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    </style>
</head>
<body class="bg-[#0f172a] text-slate-200 font-sans min-h-screen">
    <nav class="glass sticky top-0 z-50 p-4">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <a href="/" class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-[#7289DA] rounded-xl flex items-center justify-center shadow-lg shadow-[#7289DA]/20">
                        <i class="fas fa-bolt text-white"></i>
                    </div>
                    <h1 class="text-xl font-bold gradient-text">Empiria</h1>
                </a>
            </div>
            <div class="flex items-center space-x-4">
                <span class="text-slate-400 hidden sm:inline">Welcome, <%= user.username %></span>
                <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-10 h-10 rounded-full border-2 border-[#7289DA]">
                <a href="/logout" class="text-sm bg-red-500/20 text-red-400 px-3 py-1 rounded hover:bg-red-500/30 transition-all">Logout</a>
            </div>
        </div>
    </nav>

    <main class="container mx-auto mt-12 px-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- User Profile -->
            <div class="glass p-8 rounded-3xl col-span-1">
                <h2 class="text-2xl font-bold mb-6 flex items-center"><i class="fas fa-user-circle mr-3 text-[#7289DA]"></i> Profile</h2>
                <div class="space-y-4">
                    <div class="flex justify-between border-b border-slate-700/50 pb-2">
                        <span class="text-slate-400">Wallet</span>
                        <span class="font-bold text-emerald-400">$<%= dbUser ? dbUser.wallet.toLocaleString() : 0 %></span>
                    </div>
                    <div class="flex justify-between border-b border-slate-700/50 pb-2">
                        <span class="text-slate-400">Bank</span>
                        <span class="font-bold text-blue-400">$<%= dbUser ? dbUser.bank.toLocaleString() : 0 %></span>
                    </div>
                    <div class="flex justify-between border-b border-slate-700/50 pb-2">
                        <span class="text-slate-400">Clan</span>
                        <span class="font-bold text-purple-400"><%= clan ? clan.name : 'None' %></span>
                    </div>
                </div>
            </div>

            <!-- Main Controls -->
            <div class="glass p-8 rounded-3xl col-span-1 lg:col-span-2">
                <h2 class="text-2xl font-bold mb-6 flex items-center"><i class="fas fa-cogs mr-3 text-[#7289DA]"></i> Quick Actions</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <button class="bg-[#7289DA] hover:bg-[#5b6eae] p-4 rounded-2xl flex items-center space-x-4 transition-all group">
                        <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center group-hover:scale-110 transition-all">
                            <i class="fas fa-shield-alt text-xl"></i>
                        </div>
                        <div class="text-left">
                            <p class="font-bold">Moderation</p>
                            <p class="text-xs text-white/60">Configure protection</p>
                        </div>
                    </button>
                    <button class="glass hover:bg-white/10 p-4 rounded-2xl flex items-center space-x-4 transition-all group border-emerald-500/30">
                        <div class="w-12 h-12 bg-emerald-500/20 text-emerald-400 rounded-xl flex items-center justify-center group-hover:scale-110 transition-all">
                            <i class="fas fa-coins text-xl"></i>
                        </div>
                        <div class="text-left">
                            <p class="font-bold">Economy</p>
                            <p class="text-xs text-slate-400">Manage your wealth</p>
                        </div>
                    </button>
                    <button class="glass hover:bg-white/10 p-4 rounded-2xl flex items-center space-x-4 transition-all group border-purple-500/30">
                        <div class="w-12 h-12 bg-purple-500/20 text-purple-400 rounded-xl flex items-center justify-center group-hover:scale-110 transition-all">
                            <i class="fas fa-users text-xl"></i>
                        </div>
                        <div class="text-left">
                            <p class="font-bold">Clans</p>
                            <p class="text-xs text-slate-400">Manage your clan</p>
                        </div>
                    </button>
                    <button class="glass hover:bg-white/10 p-4 rounded-2xl flex items-center space-x-4 transition-all group border-blue-500/30">
                        <div class="w-12 h-12 bg-blue-500/20 text-blue-400 rounded-xl flex items-center justify-center group-hover:scale-110 transition-all">
                            <i class="fas fa-ticket-alt text-xl"></i>
                        </div>
                        <div class="text-left">
                            <p class="font-bold">Tickets</p>
                            <p class="text-xs text-slate-400">View support tickets</p>
                        </div>
                    </button>
                </div>

                <div class="mt-8 p-6 bg-yellow-500/10 border border-yellow-500/20 rounded-2xl">
                    <p class="text-sm text-yellow-200/80 italic">
                        <i class="fas fa-info-circle mr-2"></i> Settings saving functionality is being deployed in real-time. Full control panel access available shortly.
                    </p>
                </div>
            </div>
        </div>
    </main>

    <footer class="mt-24 pb-12 text-center text-slate-500 text-sm">
        &copy; 2026 Empiria Bot Team. All rights reserved.
    </footer>
</body>
</html>
