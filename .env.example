# ──────────────────────────────────────────────────────────────
#  EMPIRIA BOT v2 — Environment Variables
# ──────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# REQUIRED — Discord bot token from https://discord.com/developers/applications
TOKEN=your_discord_bot_token_here

# REQUIRED — MongoDB connection string (MongoDB Atlas or local)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/empiria

# Bot command prefix (default: $)
PREFIX=$

# Your Discord user ID (for owner-only commands)
BOT_OWNER_ID=your_discord_user_id

# Web dashboard port (default: 3000)
PORT=3000

# OPTIONAL — Spotify integration for music (if using voice features)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
